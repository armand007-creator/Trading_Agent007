PYTHONUNBUFFERED=1
LOG_LEVEL=INFO
TRADING_LOOP_INTERVAL_SECONDS=30
CLOSE_POSITIONS_ON_SHUTDOWN=true

# Coinbase credentials
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINBASE_API_PASSPHRASE=
COINBASE_API_BASE_URL=https://api.coinbase.com

# Optional derivatives-specific keys
COINBASE_DERIV_API_KEY=
COINBASE_DERIV_API_SECRET=
COINBASE_DERIV_API_PASSPHRASE=
COINBASE_DERIV_API_BASE_URL=https://api.coinbase.com

# Risk and portfolio controls
MAX_TOTAL_EXPOSURE_PCT=0.85
MAX_DAILY_DRAWDOWN_PCT=0.08
MAX_CORRELATED_EXPOSURE_PCT=0.45
MAX_OPEN_POSITIONS=8
MAX_WALLET_RISK_PCT=0.30
MAX_LEVERAGE=5.0
MIN_LIQUIDATION_BUFFER_PCT=0.15

# Capital allocation defaults (must sum to 1)
ALLOC_SPOT=0.40
ALLOC_FUTURES=0.35
ALLOC_PERPS=0.25

# Strategy defaults
EMA_FAST=20
EMA_SLOW=50
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
ATR_PERIOD=14
VOLUME_LOOKBACK=20
